RewriteEngine On

# 1. Redirigir externamente de forma permanente (301) si alguien escribe manualmente la extensión .html
# Esto evita contenido duplicado en Google (ej. de /sucursales/hermosillo.html a /sucursales/hermosillo)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Cargar internamente el archivo .html correspondiente cuando se consulta una URL limpia
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*?)/?$ $1.html [L]
